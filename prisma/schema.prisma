generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  role         Role     @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
}

model Project {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  description String
  content     String?
  gitHubUrl   String?
  demoUrl     String?
  thumbnail   String?
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  skills      ProjectSkill[]
}

model Skill {
  id        String         @id @default(uuid())
  name      String
  icon      String?
  category  SkillCategory
  createdAt DateTime       @default(now())
  projects  ProjectSkill[]
}

model ProjectSkill {
  projectId String
  skillId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
}

model Experience {
  id          String    @id @default(uuid())
  company     String
  position    String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  currentJob  Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

enum SkillCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  DESIGN
  OTHER
}
